<?xml version="1.0" encoding="utf-8"?>
<!--
  Repository-local NuGet configuration.

  We <clear/> the inherited package sources before adding our own so the build
  is independent of whatever feeds happen to be configured on a developer or
  CI host. This makes restore reproducible across machines.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <config>
    <add key="signatureValidationMode" value="accept" />
  </config>
</configuration>
