<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Autofire.App.ViewModels"
             x:Class="Autofire.App.Views.MappingEditorView"
             x:DataType="vm:MappingEditorViewModel"
             x:CompileBindings="False">

  <UserControl.Resources>
    <DataTemplate x:Key="RuleKindTemplate">
      <StackPanel Margin="0,3" Spacing="2">
        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="#E2E8F0" />
        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#64748B" TextWrapping="Wrap" />
      </StackPanel>
    </DataTemplate>
  </UserControl.Resources>

  <Grid ColumnDefinitions="*,380" ColumnSpacing="14" Margin="20,16">

    <!-- ══ LEFT: Rule list ══════════════════════════════════════════ -->
    <Grid RowDefinitions="Auto,*" RowSpacing="12">

      <!-- Add toolbar -->
      <Border Grid.Row="0" Padding="14,12" CornerRadius="14"
              Background="#08111E" BorderBrush="#162740" BorderThickness="1">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <StackPanel Spacing="4">
            <TextBlock Text="MAPPING RULES" FontSize="10" FontWeight="Bold"
                       Foreground="#475569" LetterSpacing="1" />
            <ComboBox ItemsSource="{Binding RuleKindOptions}"
                      SelectedItem="{Binding SelectedNewRuleKind}"
                      ItemTemplate="{StaticResource RuleKindTemplate}" />
          </StackPanel>
          <Button Grid.Column="1" Classes="primary" VerticalAlignment="Bottom"
                  Padding="16,10" Command="{Binding AddRuleCommand}"
                  Content="+ Add rule" />
        </Grid>
      </Border>

      <!-- Rule cards -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Rules}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,8" Padding="14,12" CornerRadius="12"
                      Background="#08111E" BorderBrush="#162740" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                  <!-- Badge + toggle -->
                  <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                    <Border Padding="8,4" CornerRadius="6"
                            Background="{Binding KindBadgeColor}">
                      <TextBlock Text="{Binding KindLabel}" FontSize="9.5"
                                 FontWeight="Bold" Foreground="#040C16"
                                 LetterSpacing="0.5" />
                    </Border>
                    <CheckBox IsChecked="{Binding Enabled}"
                              HorizontalAlignment="Center"
                              ToolTip.Tip="Enable / disable this rule" />
                  </StackPanel>

                  <!-- Name + summary -->
                  <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                               FontSize="13" Foreground="#E2E8F0" />
                    <TextBlock Text="{Binding SummaryText}" FontSize="11.5"
                               Foreground="#64748B" TextWrapping="Wrap"
                               FontFamily="Cascadia Code,Consolas,monospace" />
                  </StackPanel>

                  <!-- Action buttons -->
                  <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="ghost" Padding="10,6" FontSize="12"
                            Command="{Binding $parent[ItemsControl].DataContext.EditRuleCommand}"
                            CommandParameter="{Binding}"
                            Content="Edit" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="4">
                      <Button Grid.Column="0" Classes="ghost" Padding="6,5" FontSize="11"
                              Command="{Binding $parent[ItemsControl].DataContext.MoveUpCommand}"
                              CommandParameter="{Binding}"
                              Content="↑" ToolTip.Tip="Move up" />
                      <Button Grid.Column="1" Classes="ghost" Padding="6,5" FontSize="11"
                              Command="{Binding $parent[ItemsControl].DataContext.MoveDownCommand}"
                              CommandParameter="{Binding}"
                              Content="↓" ToolTip.Tip="Move down" />
                    </Grid>
                    <Button Classes="danger" Padding="10,5" FontSize="11"
                            Command="{Binding $parent[ItemsControl].DataContext.DeleteRuleCommand}"
                            CommandParameter="{Binding}"
                            Content="Delete" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <!-- ══ RIGHT: Edit form ══════════════════════════════════════════ -->
    <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="0">

      <!-- Empty state — shown when not editing -->
      <Border Grid.Row="0" Grid.RowSpan="2"
              Padding="24" CornerRadius="16"
              Background="#08111E" BorderBrush="#162740" BorderThickness="1"
              IsVisible="{Binding IsNotEditing}"
              VerticalAlignment="Center">
        <StackPanel Spacing="12" HorizontalAlignment="Center">
          <TextBlock Text="⊞" FontSize="32" Foreground="#162740"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Select a rule to edit" FontSize="14"
                     FontWeight="SemiBold" Foreground="#334155"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Or use 'Add rule' to create a new mapping."
                     FontSize="12" Foreground="#1E3A5A" TextWrapping="Wrap"
                     HorizontalAlignment="Center" TextAlignment="Center"
                     MaxWidth="240" />
        </StackPanel>
      </Border>

      <!-- Edit form — shown when editing -->
      <Border Grid.Row="0" Grid.RowSpan="2"
              CornerRadius="16"
              Background="#08111E" BorderBrush="#162740" BorderThickness="1"
              IsVisible="{Binding IsEditing}">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="20,18" Spacing="16"
                      DataContext="{Binding EditingRule}">

            <!-- Form header -->
            <StackPanel Spacing="3">
              <Border Padding="10,5" CornerRadius="6"
                      Background="{Binding KindBadgeColor}"
                      HorizontalAlignment="Left">
                <TextBlock Text="{Binding KindLabel}" FontSize="10"
                           FontWeight="Bold" Foreground="#040C16" LetterSpacing="0.5" />
              </Border>
              <TextBlock Text="{Binding $parent[StackPanel].DataContext.(vm:MappingEditorViewModel.EditPanelTitle), FallbackValue='Edit rule'}"
                         FontSize="15" FontWeight="SemiBold" Foreground="White" />
            </StackPanel>

            <Border Height="1" Background="#0F2035" />

            <!-- ── Common fields ──────────────────────────────────── -->
            <StackPanel Spacing="5">
              <TextBlock Text="RULE NAME" FontSize="10" FontWeight="SemiBold"
                         Foreground="#475569" LetterSpacing="0.8" />
              <TextBox Text="{Binding Name}" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
              <StackPanel Grid.Column="0" Spacing="5">
                <TextBlock Text="MODE" FontSize="10" FontWeight="SemiBold"
                           Foreground="#475569" LetterSpacing="0.8" />
                <ComboBox ItemsSource="{Binding AllModeOptions, Mode=OneTime}"
                          SelectedItem="{Binding SelectedModeOption}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Bottom">
                <CheckBox IsChecked="{Binding Enabled}"
                          Content="Enabled" />
              </StackPanel>
            </Grid>

            <!-- ── Button remap / autofire fields ─────────────────── -->
            <StackPanel Spacing="12"
                        IsVisible="{Binding IsButtonRemap}">
              <Border Height="1" Background="#0A1A2C" />
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <StackPanel Grid.Column="0" Spacing="5">
                  <TextBlock Text="SOURCE BUTTON" FontSize="10" FontWeight="SemiBold"
                             Foreground="#4F8CFF" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllButtonOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedSourceButtonOption}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5">
                  <TextBlock Text="TARGET BUTTON" FontSize="10" FontWeight="SemiBold"
                             Foreground="#4F8CFF" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllButtonOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedTargetButtonOption}" />
                </StackPanel>
              </Grid>
              <CheckBox IsChecked="{Binding SuppressSourceButton}"
                        Content="Suppress source button (block original)" />
            </StackPanel>

            <StackPanel Spacing="12"
                        IsVisible="{Binding IsButtonAutofire}">
              <Border Height="1" Background="#0A1A2C" />
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <StackPanel Grid.Column="0" Spacing="5">
                  <TextBlock Text="TRIGGER BUTTON" FontSize="10" FontWeight="SemiBold"
                             Foreground="#F97316" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllButtonOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedSourceButtonOption}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5">
                  <TextBlock Text="OUTPUT BUTTON" FontSize="10" FontWeight="SemiBold"
                             Foreground="#F97316" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllButtonOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedTargetButtonOption}" />
                </StackPanel>
              </Grid>
              <CheckBox IsChecked="{Binding SuppressSourceButton}"
                        Content="Suppress source button (block original)" />
            </StackPanel>

            <!-- ── Stick threshold fields ──────────────────────────── -->
            <StackPanel Spacing="12"
                        IsVisible="{Binding IsStickThreshold}">
              <Border Height="1" Background="#0A1A2C" />
              <StackPanel Spacing="5">
                <TextBlock Text="TARGET STICK" FontSize="10" FontWeight="SemiBold"
                           Foreground="#10B981" LetterSpacing="0.8" />
                <ComboBox ItemsSource="{Binding AllStickOptions, Mode=OneTime}"
                          SelectedItem="{Binding SelectedTargetStickOption}" />
              </StackPanel>
              <!-- Deadzone -->
              <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="DEADZONE" FontSize="10" FontWeight="SemiBold"
                             Foreground="#10B981" LetterSpacing="0.8" />
                  <TextBlock Grid.Column="1" Text="{Binding DeadzoneText}"
                             FontSize="12" Foreground="#00D4FF"
                             FontFamily="Cascadia Code,Consolas,monospace" />
                </Grid>
                <Slider Minimum="0" Maximum="0.50" SmallChange="0.01" LargeChange="0.05"
                        Value="{Binding Deadzone}" />
                <TextBlock Text="Ignore stick movement below this threshold."
                           FontSize="11" Foreground="#334155" />
              </StackPanel>
              <!-- Full at -->
              <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="FULL AT (saturation)" FontSize="10" FontWeight="SemiBold"
                             Foreground="#10B981" LetterSpacing="0.8" />
                  <TextBlock Grid.Column="1" Text="{Binding FullAtText}"
                             FontSize="12" Foreground="#00D4FF"
                             FontFamily="Cascadia Code,Consolas,monospace" />
                </Grid>
                <Slider Minimum="0.50" Maximum="1.0" SmallChange="0.01" LargeChange="0.05"
                        Value="{Binding FullAt}" />
                <TextBlock Text="Reach 100% output at this raw stick magnitude."
                           FontSize="11" Foreground="#334155" />
              </StackPanel>
            </StackPanel>

            <!-- ── Stick autofire fields ───────────────────────────── -->
            <StackPanel Spacing="12"
                        IsVisible="{Binding IsStickAutofire}">
              <Border Height="1" Background="#0A1A2C" />
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <StackPanel Grid.Column="0" Spacing="5">
                  <TextBlock Text="SOURCE STICK" FontSize="10" FontWeight="SemiBold"
                             Foreground="#A78BFA" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllStickOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedSourceStickOption}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5">
                  <TextBlock Text="TARGET STICK" FontSize="10" FontWeight="SemiBold"
                             Foreground="#A78BFA" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllStickOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedTargetStickOption}" />
                </StackPanel>
              </Grid>
              <StackPanel Spacing="5">
                <TextBlock Text="BLEND MODE" FontSize="10" FontWeight="SemiBold"
                           Foreground="#A78BFA" LetterSpacing="0.8" />
                <ComboBox ItemsSource="{Binding AllBlendModeOptions, Mode=OneTime}"
                          SelectedItem="{Binding SelectedBlendModeOption}" />
              </StackPanel>
              <CheckBox IsChecked="{Binding SuppressSourceStick}"
                        Content="Suppress source stick output" />
              <!-- Deadzone for stick autofire -->
              <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="ACTIVATION DEADZONE" FontSize="10" FontWeight="SemiBold"
                             Foreground="#A78BFA" LetterSpacing="0.8" />
                  <TextBlock Grid.Column="1" Text="{Binding DeadzoneText}"
                             FontSize="12" Foreground="#00D4FF"
                             FontFamily="Cascadia Code,Consolas,monospace" />
                </Grid>
                <Slider Minimum="0" Maximum="0.50" SmallChange="0.01"
                        Value="{Binding Deadzone}" />
              </StackPanel>
            </StackPanel>

            <!-- ── Freeze last direction fields ───────────────────── -->
            <StackPanel Spacing="12"
                        IsVisible="{Binding IsFreeze}">
              <Border Height="1" Background="#0A1A2C" />
              <StackPanel Spacing="5">
                <TextBlock Text="ACTIVATION BUTTON (hold to freeze)" FontSize="10"
                           FontWeight="SemiBold" Foreground="#00D4FF" LetterSpacing="0.8" />
                <ComboBox ItemsSource="{Binding AllButtonOptions, Mode=OneTime}"
                          SelectedItem="{Binding SelectedActivationButtonOption}" />
              </StackPanel>
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <StackPanel Grid.Column="0" Spacing="5">
                  <TextBlock Text="CAPTURE STICK" FontSize="10" FontWeight="SemiBold"
                             Foreground="#00D4FF" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllStickOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedCaptureStickOption}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="5">
                  <TextBlock Text="OUTPUT STICK" FontSize="10" FontWeight="SemiBold"
                             Foreground="#00D4FF" LetterSpacing="0.8" />
                  <ComboBox ItemsSource="{Binding AllStickOptions, Mode=OneTime}"
                            SelectedItem="{Binding SelectedTargetStickOption}" />
                </StackPanel>
              </Grid>
              <StackPanel Spacing="5">
                <TextBlock Text="BLEND MODE" FontSize="10" FontWeight="SemiBold"
                           Foreground="#00D4FF" LetterSpacing="0.8" />
                <ComboBox ItemsSource="{Binding AllBlendModeOptions, Mode=OneTime}"
                          SelectedItem="{Binding SelectedBlendModeOption}" />
              </StackPanel>
              <CheckBox IsChecked="{Binding PulseEnabled}"
                        Content="Pulse while frozen (autofire while held)" />
            </StackPanel>

            <!-- ── Timing fields (autofire / freeze) ─────────────── -->
            <StackPanel Spacing="12"
                        IsVisible="{Binding ShowPulseTiming}">
              <Border Height="1" Background="#0A1A2C" />
              <TextBlock Text="TIMING" FontSize="10" FontWeight="SemiBold"
                         Foreground="#475569" LetterSpacing="0.8" />
              <!-- Hold -->
              <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="HOLD" FontSize="10" FontWeight="SemiBold"
                             Foreground="#475569" LetterSpacing="0.8" />
                  <TextBlock Grid.Column="1" Text="{Binding HoldMsText}"
                             FontSize="12" Foreground="#00D4FF"
                             FontFamily="Cascadia Code,Consolas,monospace" />
                </Grid>
                <Slider Minimum="8" Maximum="500" SmallChange="4" LargeChange="16"
                        Value="{Binding HoldMs}" />
                <TextBlock Text="How long the virtual button is held (pressed phase)."
                           FontSize="11" Foreground="#334155" />
              </StackPanel>
              <!-- Release -->
              <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="RELEASE" FontSize="10" FontWeight="SemiBold"
                             Foreground="#475569" LetterSpacing="0.8" />
                  <TextBlock Grid.Column="1" Text="{Binding ReleaseMsText}"
                             FontSize="12" Foreground="#00D4FF"
                             FontFamily="Cascadia Code,Consolas,monospace" />
                </Grid>
                <Slider Minimum="4" Maximum="500" SmallChange="4" LargeChange="16"
                        Value="{Binding ReleaseMs}" />
                <TextBlock Text="How long the virtual button is released between pulses."
                           FontSize="11" Foreground="#334155" />
              </StackPanel>
            </StackPanel>

            <!-- ── Save / Cancel ──────────────────────────────────── -->
            <Border Height="1" Background="#0F2035" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <Button Grid.Column="0" Classes="primary" Padding="0,11"
                      HorizontalAlignment="Stretch"
                      Command="{Binding $parent[StackPanel].DataContext.(vm:MappingEditorViewModel.SaveEditCommand), FallbackValue={x:Null}}"
                      Content="Save rule" />
              <Button Grid.Column="1" Classes="ghost" Padding="16,11"
                      Command="{Binding $parent[StackPanel].DataContext.(vm:MappingEditorViewModel.CancelEditCommand), FallbackValue={x:Null}}"
                      Content="Cancel" />
            </Grid>

          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
