<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GameFlow.App.Views.RequirementsDialog"
        Width="640"
        MinHeight="320"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#050B12"
        Title="Missing requirements">

  <Border Margin="0"
          ClipToBounds="True"
          Background="#07101D"
          BorderBrush="#0F2035"
          BorderThickness="1">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24,20,24,20" RowSpacing="16">

      <!-- Header -->
      <StackPanel Grid.Row="0" Spacing="6">
        <TextBlock Text="Some optional components aren't installed"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White" />
        <TextBlock Text="GameFlow can run without them, but parts of the feature set will be unavailable until they're installed."
                   FontSize="12"
                   Foreground="#94A3B8"
                   TextWrapping="Wrap" />
      </StackPanel>

      <!-- Per-requirement list — populated from code-behind -->
      <ItemsControl Grid.Row="1"
                    Name="RequirementsList"
                    Margin="0,4,0,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,0,0,10"
                    Padding="14,12"
                    Background="#0A1628"
                    BorderBrush="#1E3A5A"
                    BorderThickness="1"
                    CornerRadius="6">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Spacing="4">
                  <TextBlock Text="{Binding DisplayName}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="White" />
                  <TextBlock Text="{Binding Description}"
                             FontSize="11.5"
                             Foreground="#94A3B8"
                             TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Open install page"
                        Tag="{Binding}"
                        Click="OnOpenInstallPageClick"
                        VerticalAlignment="Center"
                        Padding="14,6"
                        Background="#0F2535"
                        Foreground="White"
                        BorderBrush="#22DEFF"
                        BorderThickness="1" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Footer buttons -->
      <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
        <CheckBox Grid.Column="0"
                  Name="DontAskAgainCheckbox"
                  Content="Don't check at startup again"
                  Foreground="#94A3B8"
                  VerticalAlignment="Center" />

        <Button Grid.Column="2"
                Content="Close"
                IsDefault="True"
                IsCancel="True"
                Click="OnCloseClick"
                Padding="20,8"
                Background="#00D4FF"
                Foreground="#040C16"
                BorderThickness="0"
                FontWeight="SemiBold" />
      </Grid>

    </Grid>
  </Border>
</Window>
