<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:GameFlow.App.Views"
             xmlns:vm="using:GameFlow.App.ViewModels"
             x:Class="GameFlow.App.Views.ControllerSurface"
             x:DataType="vm:ControllerVisualStateViewModel"
             x:CompileBindings="False">

    <!--
        Outer Border background is bound to the VM so the user can flip
        the panel between solid (default "#09111B") and "Transparent"
        for the see-through effect described in design point 6.
    -->
    <!--
        Chrome follows the app theme live (DynamicResource); the user's
        background preset paints an overlay layer above it. A null overlay
        (the "Theme default" preset) lets the themed base show through, so
        switching the app theme recolours the panel immediately.
    -->
    <Border CornerRadius="14"
            Background="{DynamicResource AppSurface1}"
            BorderBrush="{DynamicResource AppBorder0}" BorderThickness="1">
      <Border Padding="18,14" CornerRadius="14"
              Background="{Binding PanelOverlayBrush}">
        <Grid RowDefinitions="Auto,Auto,*,Auto" MinHeight="260">

            <!-- Title row -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppForeground}" />
                <TextBlock Grid.Column="1" Text="{Binding ConnectionLabel}"
                           FontSize="10" Foreground="{Binding ConnectionBrush}"
                           FontWeight="SemiBold" LetterSpacing="1" />
            </Grid>

            <!--
                Variant picker — shows every theme installed for the
                current visual style so the user can swap colour/skin
                without leaving the screen. Hidden when no themes are
                installed for the current style.
            -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,0,0,8"
                  IsVisible="{Binding HasThemeVariants}">
                <TextBlock Text="Skin:" VerticalAlignment="Center" Margin="0,0,8,0"
                           FontSize="11" Foreground="#94A3B8" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableThemeVariants}"
                          SelectedItem="{Binding SelectedThemeVariant, Mode=TwoWay}"
                          MinHeight="28" FontSize="11"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="2">
                <TextBlock x:Name="NoThemeMessage"
                           IsVisible="False"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           MaxWidth="360" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="#64748B" Opacity="0.85" FontSize="12"
                           Text="No controller theme installed for this style. Drop a VSCView-compatible theme folder into %LocalAppData%\GAMEFLOW\themes." />
                <views:ThemeSurface x:Name="ThemedSurface"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />
            </Grid>

            <TextBlock Grid.Row="3" Text="{Binding PressedButtonsText}"
                       Margin="0,8,0,0" FontSize="11" Foreground="#94A3B8" />
        </Grid>
    </Border>
    </Border>
</UserControl>
