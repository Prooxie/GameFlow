<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:themes="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="GameFlow.App.App"
             RequestedThemeVariant="Dark">

  <!-- Seed the default Cyber Blue color palette so DynamicResource bindings
       resolve immediately on first paint (before AppThemeService is called). -->
  <Application.Resources>
    <ResourceDictionary>
      <!--
          Themes/DesignTokens.axaml and Themes/Typography.axaml were built
          (see the "Design System v2" banner at the top of AppTheme.axaml)
          but never actually merged in here — every DynamicResource lookup
          against a token defined only in those files (Semantic.Danger and
          Semantic.DangerSoft among them) has been silently failing since
          they were written. That's the real reason "danger"-styled
          buttons (delete/remove actions) rendered without their intended
          red border and foreground: the resource they pointed at was
          simply never reachable. Nothing in the app currently uses
          Typography.axaml's semantic TextBlock classes yet, so merging it
          has zero visible effect beyond making those classes usable —
          merging both here just finishes wiring up what was already built.
      -->
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://GameFlow.App/Themes/DesignTokens.axaml" />
      </ResourceDictionary.MergedDictionaries>

      <SolidColorBrush x:Key="AppAccent"       Color="#00D4FF" />
      <SolidColorBrush x:Key="AppAccentSoft"   Color="#0F2530" />
      <SolidColorBrush x:Key="AppAccentHover"  Color="#22DEFF" />
      <SolidColorBrush x:Key="AppBorderActive" Color="#00D4FF" />
      <SolidColorBrush x:Key="AppSurface0"     Color="#050B12" />
      <SolidColorBrush x:Key="AppSurface1"     Color="#07101D" />
      <SolidColorBrush x:Key="AppSurface2"     Color="#0A1628" />
      <SolidColorBrush x:Key="AppBorder0"      Color="#0F2035" />
      <SolidColorBrush x:Key="AppBorder1"      Color="#1E3A5A" />
      <SolidColorBrush x:Key="AppForeground"   Color="#E2E8F0" />
      <SolidColorBrush x:Key="AppForegroundDim" Color="#64748B" />
      <SolidColorBrush x:Key="AppPrimaryBtn"   Color="#040C16" />
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <themes:FluentTheme />
    <StyleInclude Source="avares://GameFlow.App/Assets/Styles/AppTheme.axaml" />
    <StyleInclude Source="avares://GameFlow.App/Themes/Typography.axaml" />
  </Application.Styles>
</Application>
