<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:themes="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="Autofire.App.App"
             RequestedThemeVariant="Dark">

  <!-- Seed the default Cyber Blue color palette so DynamicResource bindings
       resolve immediately on first paint (before AppThemeService is called). -->
  <Application.Resources>
    <SolidColorBrush x:Key="AppAccent"       Color="#00D4FF" />
    <SolidColorBrush x:Key="AppAccentSoft"   Color="#0F2530" />
    <SolidColorBrush x:Key="AppAccentHover"  Color="#22DEFF" />
    <SolidColorBrush x:Key="AppBorderActive" Color="#00D4FF" />
    <SolidColorBrush x:Key="AppSurface0"     Color="#050B12" />
    <SolidColorBrush x:Key="AppSurface1"     Color="#07101D" />
    <SolidColorBrush x:Key="AppSurface2"     Color="#0A1628" />
    <SolidColorBrush x:Key="AppBorder0"      Color="#0F2035" />
    <SolidColorBrush x:Key="AppBorder1"      Color="#1E3A5A" />
    <SolidColorBrush x:Key="AppForeground"   Color="#E2E8F0" />
    <SolidColorBrush x:Key="AppForegroundDim" Color="#64748B" />
    <SolidColorBrush x:Key="AppPrimaryBtn"   Color="#040C16" />
  </Application.Resources>

  <Application.Styles>
    <themes:FluentTheme />
    <StyleInclude Source="avares://Autofire.App/Assets/Styles/AppTheme.axaml" />
  </Application.Styles>
</Application>
