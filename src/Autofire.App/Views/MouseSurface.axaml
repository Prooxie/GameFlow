<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Autofire.App.Converters"
             x:Class="Autofire.App.Views.MouseSurface"
             x:CompileBindings="False">

  <UserControl.Resources>
    <conv:BoolToActiveBrushConverter x:Key="BoolToActiveBrush" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Border.btn">
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorder0}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="MinWidth" Value="56" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="Border.btn > StackPanel">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.btn TextBlock.lab">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Border.btn TextBlock.hint">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="8.5" />
      <Setter Property="Opacity" Value="0.55" />
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource AppSurface0}"
          BorderBrush="{DynamicResource AppBorder0}" BorderThickness="1"
          CornerRadius="10" Padding="16,14">
    <StackPanel Spacing="12">

      <!-- Top row: LMB, MMB, RMB -->
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
        <Border Classes="btn"
                Background="{Binding IsMouseLeftDown, Converter={StaticResource BoolToActiveBrush}}">
          <StackPanel>
            <TextBlock Classes="lab" Text="LMB" />
            <TextBlock Classes="hint" Text="RT (fire)" />
          </StackPanel>
        </Border>
                        <!-- Wheel: transient up/down flashes driven by the last preview frame -->
                <TextBlock Text="▲" FontSize="9" HorizontalAlignment="Center"
                           Foreground="{DynamicResource AppAccent}"
                           IsVisible="{Binding IsMouseScrollUp}" Margin="0,0,0,1" />
<Border Classes="btn" MinWidth="44"
                Background="{Binding IsMouseMiddleDown, Converter={StaticResource BoolToActiveBrush}}">
          <StackPanel>
            <TextBlock Classes="lab" Text="MMB" />
            <TextBlock Classes="hint" Text="R3" />
          </StackPanel>
        </Border>
                <TextBlock Text="▼" FontSize="9" HorizontalAlignment="Center"
                           Foreground="{DynamicResource AppAccent}"
                           IsVisible="{Binding IsMouseScrollDown}" Margin="0,1,0,0" />
        <Border Classes="btn"
                Background="{Binding IsMouseRightDown, Converter={StaticResource BoolToActiveBrush}}">
          <StackPanel>
            <TextBlock Classes="lab" Text="RMB" />
            <TextBlock Classes="hint" Text="LT (aim)" />
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Mouse body silhouette with side buttons + movement indicator -->
      <Border Background="{DynamicResource AppSurface1}"
              BorderBrush="{DynamicResource AppBorder0}" BorderThickness="1"
              CornerRadius="40,40,28,28"
              Width="180" Height="100"
              HorizontalAlignment="Center">
        <Grid>
          <StackPanel Orientation="Vertical" Spacing="4"
                      HorizontalAlignment="Left" VerticalAlignment="Center"
                      Margin="6,0,0,0">
            <Border Classes="btn" MinWidth="36" MinHeight="18" Padding="3,1"
                    Background="{Binding IsMouseButton4Down, Converter={StaticResource BoolToActiveBrush}}">
              <TextBlock Classes="hint" Text="4 / LB" />
            </Border>
            <Border Classes="btn" MinWidth="36" MinHeight="18" Padding="3,1"
                    Background="{Binding IsMouseButton5Down, Converter={StaticResource BoolToActiveBrush}}">
              <TextBlock Classes="hint" Text="5 / RB" />
            </Border>
          </StackPanel>
          <Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                  Width="60" Height="60">
            <Ellipse Canvas.Left="22" Canvas.Top="22" Width="16" Height="16"
                     Fill="{DynamicResource AppAccent}" Opacity="0.45" />
            <Line StartPoint="30,30"
                  EndPoint="{Binding MouseAimEndPoint}"
                  Stroke="{DynamicResource AppAccent}" StrokeThickness="3"
                  StrokeLineCap="Round" />
          </Canvas>
        </Grid>
      </Border>

      <TextBlock Text="Movement → right stick (aim)"
                 FontSize="11" Opacity="0.55"
                 HorizontalAlignment="Center" />
    </StackPanel>
  </Border>
</UserControl>
