<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Autofire.App.Views.SettingsDialog"
        Width="640"
        Height="560"
        MinWidth="540"
        MinHeight="380"
        MaxHeight="900"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurface0}"
        Title="{Binding TitleLabel}">

  <Border Background="{DynamicResource AppSurface1}"
          BorderBrush="{DynamicResource AppBorder0}"
          BorderThickness="1">

    <Grid RowDefinitions="*,Auto" Margin="0">

      <!-- Scrollable form content -->
      <ScrollViewer Grid.Row="0"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Padding="24,20">
        <StackPanel Spacing="20">

          <!-- Diagnostics section -->
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding DiagnosticsHeaderLabel}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppAccentHover}" />
            <Grid ColumnDefinitions="180,*" RowDefinitions="Auto" RowSpacing="6">
              <TextBlock Grid.Column="0" Text="{Binding LogLevelLabel}"
                         FontSize="12" Foreground="{DynamicResource AppForeground}"
                         VerticalAlignment="Center" />
              <ComboBox Grid.Column="1"
                        Width="200"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding AvailableLogLevels}"
                        SelectedItem="{Binding SelectedLogLevel, Mode=TwoWay}" />
            </Grid>
            <TextBlock Text="{Binding LogLevelHintLabel}"
                       FontSize="11" Foreground="{DynamicResource AppForegroundDim}"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Separator Background="{DynamicResource AppBorder0}" Height="1" />

          <!-- Paths section -->
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding PathsHeaderLabel}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppAccentHover}" />

            <StackPanel Spacing="4">
              <TextBlock Text="{Binding ProfilesDirectoryLabel}"
                         FontSize="12" Foreground="{DynamicResource AppForeground}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <TextBox Grid.Column="0"
                         Text="{Binding ProfilesDirectoryOverride, Mode=TwoWay}"
                         Watermark="{Binding CurrentProfilesPath}" />
                <Button Grid.Column="1"
                        Content="{Binding BrowseButtonLabel}"
                        Tag="profiles"
                        Click="OnBrowseClick"
                        Padding="14,6"
                        Background="{DynamicResource AppSurface2}"
                        Foreground="{DynamicResource AppForeground}"
                        BorderBrush="{DynamicResource AppBorder1}"
                        BorderThickness="1" />
              </Grid>
              <TextBlock Text="{Binding CurrentProfilesPath}"
                         FontSize="10.5" Foreground="{DynamicResource AppForegroundDim}"
                         TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel Spacing="4">
              <TextBlock Text="{Binding LogsDirectoryLabel}"
                         FontSize="12" Foreground="{DynamicResource AppForeground}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <TextBox Grid.Column="0"
                         Text="{Binding LogsDirectoryOverride, Mode=TwoWay}"
                         Watermark="{Binding CurrentLogsPath}" />
                <Button Grid.Column="1"
                        Content="{Binding BrowseButtonLabel}"
                        Tag="logs"
                        Click="OnBrowseClick"
                        Padding="14,6"
                        Background="{DynamicResource AppSurface2}"
                        Foreground="{DynamicResource AppForeground}"
                        BorderBrush="{DynamicResource AppBorder1}"
                        BorderThickness="1" />
              </Grid>
              <TextBlock Text="{Binding CurrentLogsPath}"
                         FontSize="10.5" Foreground="{DynamicResource AppForegroundDim}"
                         TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding LogsPathHintLabel}"
                         FontSize="11" Foreground="{DynamicResource AppForegroundDim}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>

          <Separator Background="{DynamicResource AppBorder0}" Height="1" />

          <!-- Startup section -->
          <StackPanel Spacing="6">
            <TextBlock Text="{Binding StartupHeaderLabel}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppAccentHover}" />
            <CheckBox IsChecked="{Binding CheckForUpdatesOnStartup, Mode=TwoWay}"
                      Content="{Binding CheckUpdatesLabel}"
                      Foreground="{DynamicResource AppForeground}" />
            <CheckBox IsChecked="{Binding CheckRequirementsOnStartup, Mode=TwoWay}"
                      Content="{Binding CheckRequirementsLabel}"
                      Foreground="{DynamicResource AppForeground}" />
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

      <!-- Footer -->
      <Border Grid.Row="1"
              Padding="20,12"
              Background="{DynamicResource AppSurface1}"
              BorderBrush="{DynamicResource AppBorder0}"
              BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">

          <TextBlock Grid.Column="0"
                     Text="{Binding StatusMessage}"
                     FontSize="11"
                     Foreground="{DynamicResource AppForegroundDim}"
                     VerticalAlignment="Center"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis" />

          <Button Grid.Column="2"
                  Content="{Binding RestoreDefaultsButtonLabel}"
                  Command="{Binding RestoreDefaultsCommand}"
                  Padding="14,8"
                  Background="{DynamicResource AppSurface2}"
                  Foreground="{DynamicResource AppForeground}"
                  BorderBrush="{DynamicResource AppBorder1}"
                  BorderThickness="1" />

          <Button Grid.Column="3"
                  Content="{Binding CancelButtonLabel}"
                  IsCancel="True"
                  Click="OnCancelClick"
                  Padding="16,8"
                  Background="{DynamicResource AppSurface2}"
                  Foreground="{DynamicResource AppForeground}"
                  BorderBrush="{DynamicResource AppBorder1}"
                  BorderThickness="1" />

          <Button Grid.Column="4"
                  Content="{Binding ApplyButtonLabel}"
                  IsDefault="True"
                  Click="OnApplyClick"
                  Padding="20,8"
                  Background="{DynamicResource AppAccent}"
                  Foreground="{DynamicResource AppPrimaryBtn}"
                  BorderThickness="0"
                  FontWeight="SemiBold" />

        </Grid>
      </Border>

    </Grid>
  </Border>
</Window>
